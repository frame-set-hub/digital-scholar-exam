# คัดลอกไฟล์นี้เป็น `.env` แล้วแก้ค่า (ไฟล์ `.env` ถูก gitignore แล้ว)
# ค่าที่ขึ้นต้นด้วย VITE_ จะถูกฝังใน bundle ฝั่งเบราว์เซอร์

# URL ของ API ฝั่ง client (ว่าง = ใช้ path สัมพัทธ์ `/api` ไปกับ Vite dev proxy)
VITE_API_BASE_URL=

# เป้าหมายของ dev proxy เมื่อเรียก `/api/...` (ใช้ใน vite.config เท่านั้น ไม่ฝังใน client)
API_PROXY_TARGET=http://localhost:8080
