# Copy this file to `.env` in the same folder (`backend/`). `.env` is gitignored.
# Values are loaded on API startup when the file exists (shell env still overrides).

# Listen port (digits only; server binds to :PORT). Omit or empty = 8080
PORT=8080

# SQLite directory (relative to process cwd, or absolute). Default matches code when unset: ./data
DATABASE_DIR=data
